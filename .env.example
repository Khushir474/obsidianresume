# API keys
OPENAI_API_KEY=sk-proj-...
OPENROUTER_API_KEY=sk-or-v1-...

# Path configuration — copy to .env and set to your local paths
JD_FILE_PATH=/path/to/your/JobSearch/JDs/YourRole.md
ROLE_INSTRUCTIONS_FOLDER=/path/to/this/repo/knowledge/roles/
EXPERIENCE_FILES_FOLDER=/path/to/this/repo/knowledge/experience
LATEX_TEMPLATE_PATH=/path/to/this/repo/knowledge/template.tex
VAULT_PATH=/path/to/your/JobSearch/
LOGS_FOLDER=/path/to/your/JobSearch/

# CrewAI settings
CREWAI_TOOLS_ALLOW_UNSAFE_PATHS=true
